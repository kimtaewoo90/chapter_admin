{
  "name": "chapter-admin-functions",
  "description": "Chapter PDF generation with Layout Engine",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "npm run build && node --test lib/layout/engine.test.js lib/layout/stickerCollage.test.js",
    "pdf:local": "npm run build && node lib/scripts/localPdfTest.js",
    "pdf:order": "npm run build && node lib/scripts/localPdfFromOrder.js"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2",
    "pdfkit": "^0.16.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.8",
    "typescript": "^5.7.3"
  },
  "private": true
}
